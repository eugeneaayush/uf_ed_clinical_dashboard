{
  "name": "uf-ed-clinical-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "UF Department of Emergency Medicine — Clinical Dashboard (React SPA, Firebase-hosted)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "aggregate": "python scripts/aggregate.py --data-dir data_raw --out public/data",
    "deploy": "npm run build && firebase deploy --only hosting"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "clsx": "^2.1.1",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^8.0.9"
  }
}
